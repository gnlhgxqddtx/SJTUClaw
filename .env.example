# SJTU LLM API 配置示例
# 复制本文件为 .env 并填入真实值。.env 已被 .gitignore 忽略，不会提交到版本库。

# API Key（从模型服务方获取，切勿泄露）
LLM_API_KEY=sk-kskblzdjdwczkbl

# API 基础地址
LLM_BASE_URL=https://models.sjtu.edu.cn/api/v1

# 默认模型调用名，可选：
#   deepseek-chat      DeepSeek V3.2 (常规模式)
#   deepseek-reasoner  DeepSeek V3.2 (思考模式)
#   minimax            MiniMax-M2.7
#   glm                GLM-5.1
#   qwen               Qwen3.5-27B
LLM_MODEL=deepseek-chat

# 也可以使用其他openai的API
